{
  "name": "ceo-scanner",
  "version": "2.0.0",
  "description": "Scan any URL for CEO (Claw Engine Optimization) readiness — how discoverable, integrable, and transactable your product is for AI agents",
  "type": "module",
  "bin": {
    "ceo-scanner": "./dist/index.js"
  },
  "main": "./dist/scanner.js",
  "types": "./dist/scanner.d.ts",
  "exports": {
    ".": {
      "import": "./dist/scanner.js",
      "types": "./dist/scanner.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/__tests__/*.test.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ceo",
    "claw-engine-optimization",
    "ai-agents",
    "llms-txt",
    "mcp",
    "a2a",
    "openapi",
    "scanner",
    "seo-for-ai"
  ],
  "author": "Christian Cattaneo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
